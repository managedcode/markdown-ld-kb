@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix kb: <https://example.com/vocab/kb#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/2026/04/what-is-a-knowledge-graph/> a schema:Article ;
  schema:name "What is a Knowledge Graph?" ;
  schema:datePublished ""^^xsd:date .

<https://example.com/id/knowledge-graph> a schema:Thing ;
  schema:name "knowledge graph" .

<https://example.com/id/google> a schema:Organization ;
  schema:name "Google" .

<https://example.com/id/google-knowledge-graph> a schema:Thing ;
  schema:name "Google Knowledge Graph" .

<https://example.com/id/wikidata> a schema:Organization ;
  schema:name "Wikidata" .

<https://example.com/id/rdf> a schema:Thing ;
  schema:name "RDF" .

<https://example.com/id/sparql> a schema:Thing ;
  schema:name "SPARQL" .

<https://example.com/id/json-ld> a schema:Thing ;
  schema:name "JSON-LD" .

<https://example.com/id/shacl> a schema:Thing ;
  schema:name "SHACL" .

<https://example.com/id/prov-o> a schema:Thing ;
  schema:name "PROV-O" .

<https://example.com/id/schemaorg> a schema:Thing ;
  schema:name "Schema.org" .

